# LeaveFlow — example environment (NFR-20, AC1, AC5)
#
# Copy to `.env` and replace every CHANGE_ME. `.env` is gitignored; this file is
# committed. No value here is a real credential or signing key.
#
# AC1 requires that the three-command setup sequence needs no configuration value
# absent from this file. Every field read by `app/core/settings.py` appears below,
# as do the variables `docker-compose.yml` interpolates.

# --- PostgreSQL container: the OWNER role -------------------------------------
# Consumed by the `postgres` service in docker-compose.yml.
#
# This is the OWNER. It owns every table and it is the role `alembic upgrade head`
# runs as (setup command two). The application never connects as this role — see the
# application role directly below, and AD-9.
POSTGRES_USER=leaveflow
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=leaveflow

# --- The APPLICATION role (AD-9, NFR-09) --------------------------------------
# A SECOND, non-owner role. This is what the FastAPI app connects as, and what the
# seed command (setup command three) runs as.
#
# WHY TWO ROLES. AD-9 requires that the application's database role hold INSERT and
# SELECT on `audit_entry` and NEITHER UPDATE NOR DELETE — that absence is what makes
# the audit trail append-only at the DATABASE rather than merely by habit in the
# repository layer (NFR-09, FR-16). A single role cannot deliver it: the app would then
# OWN `audit_entry`, and an owner cannot be denied on its own table — a REVOKE against
# it is a no-op that fails silently and green.
#
# The role is CREATED, and its grants issued, by migration 0008 — which runs as the
# owner, during setup command two. So the three-command setup is unchanged: nothing new
# to run, and an existing database picks the role up on the next `alembic upgrade head`.
# Change APP_DB_PASSWORD here and the next migration run re-syncs it.
APP_DB_USER=leaveflow_app
APP_DB_PASSWORD=CHANGE_ME_app_role_password

# --- Database URLs ------------------------------------------------------------
# There is deliberately NO DATABASE_URL and no APP_DATABASE_URL here. `app/core/
# settings.py` builds one URL PER ROLE from the values above, URL-quoting each
# password — so each password lives in exactly one place and may contain any character.
# Both remain available as explicit overrides for unusual setups, and each is honoured
# independently: overriding one role's URL never silently redirects the other's.
#
# Two vantage points, one database: host-run tooling (pytest's integration tests)
# defaults to `localhost:<POSTGRES_HOST_PORT>`; inside the compose network,
# docker-compose.yml hands the api container POSTGRES_HOST=postgres and
# POSTGRES_PORT=5432. Setting DATABASE_URL explicitly (here or in the environment)
# still works and overrides the built URL — it is for unusual setups only.

# Host port that the `postgres` service publishes. Interpolated by docker-compose.yml,
# and read by settings.py as the port for host-run tooling — one knob, both readers.
#
# PORT 5433, NOT 5432. A developer machine very often already runs a PostgreSQL on
# 5432. Publishing there would make a host-run `alembic upgrade head` migrate
# whichever database answered first — silently, and not necessarily this project's.
# The container listens on 5432 internally; only the published host port is moved.
POSTGRES_HOST_PORT=5433

# --- Proxy (NFR-06, AC4) ------------------------------------------------------
# The `proxy` service terminates TLS. Only this port is published: no plaintext
# port is exposed at all, so credentials and tokens cannot travel unencrypted.
#
# 8443 rather than 443 because binding a host port below 1024 requires privilege the
# local container runtime may not have. A deployed environment sets this to 443.
PROXY_HTTPS_PORT=8443

# --- JWT (AD-14) --------------------------------------------------------------
# Story 1.2 consumes these. Generate a real key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# --- Seed command (AD-11) -----------------------------------------------------
# The seed command — never a migration — inserts data. In this story it seeds
# nothing and exits 0; Story 1.2 seeds the Admin and their Department, and
# Story 2.1 seeds the EL, CL and FL Leave Types.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_password
SEED_ADMIN_FULL_NAME="LeaveFlow Administrator"
SEED_DEPARTMENT_NAME=Administration
